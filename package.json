    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.503.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.2.0"
  },
  "optionalDependencies": {
    "@mobrowser/sdk-darwin-arm64": "2.8.0",
    "@mobrowser/sdk-linux-x64": "2.8.0",
    "@mobrowser/sdk-win-x64": "2.8.0"
  },
  "devDependencies": {

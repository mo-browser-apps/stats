{
  "name": "MoStats",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "mobrowser dev",
    "build": "mobrowser build",
    "gen": "mobrowser gen",
    "mobrowser": "mobrowser",
    "lint": "eslint . --max-warnings=0",
